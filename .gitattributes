<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>Wlafē Roastery Ultimate</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  <link
    href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;800;900&family=Poppins:wght@300;400;500;600&display=swap"
    rel="stylesheet">

  <style>
    :root {
      --dark: #2C1A0E;
      --brown: #6B3F20;
      --gold: #C9963B;
      --cream: #FAF5EC;
      --light: #fff;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      scroll-behavior: smooth;
    }

    body {
      font-family: 'Poppins', sans-serif;
      background: var(--cream);
      color: var(--dark);
      overflow-x: hidden;
    }

    h1,
    h2,
    h3 {
      font-family: 'Montserrat', sans-serif;
    }

    .page {
      display: none;
      padding-top: 90px;
      min-height: 100vh;
    }

    .page.active {
      display: block;
    }

    /* NAVBAR */

    .navbar {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      padding: 18px 5%;
      background: rgba(44, 26, 14, .92);
      display: flex;
      justify-content: space-between;
      align-items: center;
      z-index: 9999;
      backdrop-filter: blur(10px);
    }

    .logo {
      font-size: 2rem;
      font-weight: 900;
      color: white;
    }

    .nav-links {
      display: flex;
      gap: 20px;
      align-items: center;
    }

    .nav-links a {
      color: white;
      text-decoration: none;
      cursor: pointer;
      transition: .3s;
    }

    .nav-links a:hover {
      color: var(--gold);
    }

    .hamburger {
      display: none;
      font-size: 2rem;
      color: white;
      cursor: pointer;
    }

    /* HERO */

    .hero {
      min-height: 100vh;
      background:
        linear-gradient(rgba(0, 0, 0, .55), rgba(0, 0, 0, .55)),
        url('https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?q=80&w=1600&auto=format&fit=crop');
      background-size: cover;
      background-position: center;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 40px;
      text-align: center;
      color: white;
    }

    .hero-content {
      max-width: 900px;
    }

    .hero h1 {
      font-size: 5rem;
      margin-bottom: 20px;
    }

    .hero p {
      font-size: 1.1rem;
      line-height: 1.8;
      margin-bottom: 30px;
    }

    .hero-buttons {
      display: flex;
      justify-content: center;
      gap: 20px;
      flex-wrap: wrap;
    }

    .hero-gallery {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 20px;
      margin-top: 50px;
    }

    .hero-gallery img {
      width: 100%;
      height: 260px;
      object-fit: cover;
      border-radius: 24px;
      box-shadow: 0 10px 20px rgba(0, 0, 0, .2);
      transition: .4s;
    }

    .hero-gallery img:hover {
      transform: scale(1.03);
    }

    /* BUTTON */

    .btn {
      padding: 14px 28px;
      border: none;
      border-radius: 999px;
      cursor: pointer;
      font-weight: 600;
      transition: .3s;
    }

    .btn:hover {
      transform: translateY(-3px);
    }

    .btn-primary {
      background: var(--gold);
      color: black;
    }

    .btn-outline {
      background: transparent;
      border: 1px solid white;
      color: white;
    }

    /* SECTION */

    .container {
      width: 90%;
      max-width: 1400px;
      margin: auto;
    }

    section {
      padding: 80px 0;
    }

    .section-title {
      text-align: center;
      margin-bottom: 50px;
    }

    .section-title h2 {
      font-size: 3rem;
      margin-bottom: 10px;
    }

    /* GRID */

    /* MENU GRID */

    .grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 30px;
    }

    @media(max-width:1200px) {
      .grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    @media(max-width:900px) {
      .grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media(max-width:600px) {
      .grid {
        grid-template-columns: repeat(1, 1fr);
      }
    }

    /* CARD */

    .card {
      background: #ffffff;
      border-radius: 28px;
      overflow: hidden;
      box-shadow: 0 10px 25px rgba(0, 0, 0, .08);
      transition: .3s;
      display: flex;
      flex-direction: column;
    }

    .card:hover {
      transform: translateY(-8px);
    }

    .card img {
      width: 100%;
      height: 260px;
      object-fit: cover;
      transition: .4s;
    }

    .card:hover img {
      transform: scale(1.05);
    }

    .card-content {
      padding: 24px;
      display: flex;
      flex-direction: column;
      flex: 1;
    }

    .card-content h3 {
      font-size: 1.6rem;
      margin-bottom: 10px;
      color: #2C1A0E;
    }

    .price {
      font-size: 1.1rem;
      font-weight: 700;
      color: #8B5E34;
      margin-bottom: 20px;
    }

    .card-content .btn {
      width: 100%;
      padding: 15px;
      border: none;
      border-radius: 999px;
      background: #9C6B43;
      color: white;
      font-weight: 600;
      cursor: pointer;
      transition: .3s;
      margin-top: auto;
    }

    .card-content .btn:hover {
      background: #7c5334;
    }

    /* IMAGE */

    .card img {
      width: 100%;
      height: 270px;
      object-fit: cover;
      display: block;
    }

    /* CONTENT */

    .card-content {
      padding: 24px;
      display: flex;
      flex-direction: column;
      flex: 1;
      justify-content: space-between;
    }

    /* TITLE */

    .card-content h3 {
      font-size: 1.4rem;
      margin-bottom: 10px;
    }

    /* PRICE */

    .price {
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--brown);
      margin: 10px 0 20px;
    }

    .card-content .btn {
      width: 100%;
      margin-top: 15px;
      padding: 16px;
      border-radius: 999px;
      background: #9C6B43;
      color: white;
      font-weight: 600;
    }

    /* BUTTON */

    .card-content .btn {
      width: 100%;
    }

    /* CARD */

    .card {
      background: white;
      border-radius: 24px;
      overflow: hidden;
      box-shadow: 0 10px 30px rgba(0, 0, 0, .08);
      transition: .3s;
    }

    .card:hover {
      transform: translateY(-8px);
    }

    .card img {
      width: 100%;
      height: 240px;
      object-fit: cover;
    }

    .card-content {
      padding: 24px;
    }

    .price {
      margin: 14px 0;
      font-weight: 700;
      color: var(--brown);
    }

    /* FILTER */

    .filter-buttons {
      display: flex;
      justify-content: center;
      gap: 14px;
      margin-bottom: 40px;
      flex-wrap: wrap;
    }

    .filter-btn {
      padding: 12px 20px;
      border: none;
      border-radius: 999px;
      background: white;
      cursor: pointer;
      font-weight: 600;
    }

    .filter-btn.active {
      background: var(--brown);
      color: white;
    }

    /* DASHBOARD */

    .dashboard-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 20px;
    }

    .dashboard-card {
      background: white;
      padding: 25px;
      border-radius: 24px;
      box-shadow: 0 10px 20px rgba(0, 0, 0, .08);
    }

    .stock-warning {
      margin-top: 15px;
      color: red;
      font-weight: bold;
    }

    /* CART */

    .cart-sidebar {
      position: fixed;
      right: -420px;
      top: 0;
      width: 400px;
      height: 100%;
      background: white;
      padding: 30px;
      transition: .4s;
      z-index: 99999;
      overflow-y: auto;
      box-shadow: -10px 0 20px rgba(0, 0, 0, .1);
    }

    .cart-sidebar.active {
      right: 0;
    }

    .cart-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 20px;
    }

    .close-cart {
      font-size: 34px;
      cursor: pointer;
      font-weight: bold;
    }

    .cart-item {
      display: flex;
      justify-content: space-between;
      margin-bottom: 20px;
    }

    .qty button {
      width: 28px;
      height: 28px;
      border: none;
      border-radius: 50%;
      cursor: pointer;
    }

    /* MODAL */

    .modal {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, .6);
      display: none;
      justify-content: center;
      align-items: center;
      z-index: 999999;
    }

    .modal-box {
      background: white;
      padding: 30px;
      border-radius: 24px;
      width: 90%;
      max-width: 500px;
    }

    /* FORM */

    input,
    textarea,
    select {
      width: 100%;
      padding: 14px;
      margin-top: 10px;
      margin-bottom: 16px;
      border-radius: 12px;
      border: 1px solid #ddd;
    }

    /* PAYMENT */

    .payment-options {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
      margin: 20px 0;
    }

    .payment-option {
      padding: 16px;
      border: 2px solid #ddd;
      border-radius: 16px;
      text-align: center;
      cursor: pointer;
    }

    .payment-option.active {
      border-color: var(--gold);
      background: #fff5dd;
    }

    /* REVIEW */

    .review-card {
      background: white;
      padding: 20px;
      border-radius: 20px;
      margin-top: 20px;
    }

    /* TABLE */

    .stock-table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 20px;
    }

    .stock-table th,
    .stock-table td {
      padding: 14px;
      border-bottom: 1px solid #ddd;
      text-align: left;
    }

    /* FOOTER */

    .footer {
      background: var(--dark);
      color: white;
      padding: 60px 5%;
      margin-top: 80px;
    }

    .footer-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 30px;
    }

    /* TOAST */

    .toast {
      position: fixed;
      bottom: 30px;
      right: 30px;
      background: var(--dark);
      color: white;
      padding: 15px 24px;
      border-radius: 14px;
      display: none;
      z-index: 999999;
    }

    /* MOBILE */

    @media(max-width:768px) {

      .hero h1 {
        font-size: 3rem;
      }

      .nav-links {
        display: none;
        position: absolute;
        top: 80px;
        left: 0;
        right: 0;
        background: var(--dark);
        padding: 20px;
        flex-direction: column;
      }

      .nav-links.show {
        display: flex;
      }

      .hamburger {
        display: block;
      }

      .cart-sidebar {
        width: 100%;
      }

    }
  </style>
</head>

<body>

  <!-- NAVBAR -->

  <div class="navbar">

    <div class="logo">Wlafē</div>

    <div class="nav-links" id="navLinks">

      <a onclick="showPage('home')">Home</a>
      <a onclick="showPage('menu')">Menu</a>
      <a onclick="showPage('dashboard')">Dashboard</a>
      <a onclick="showPage('reviews')">Reviews</a>
      <a onclick="showPage('reservation')">Reservation</a>
      <a onclick="showPage('contact')">Contact</a>

      <a onclick="toggleCart()">
        Cart (<span id="cartCount">0</span>)
      </a>

      <a onclick="openAuth()">
