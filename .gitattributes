  <!-- DASHBOARD -->

  <div id="dashboard" class="page">

    <section class="container">

      <div class="section-title">

        <h2>Admin Dashboard</h2>

        <p>Customer • Barista • Moderator System</p>

      </div>

      <div class="dashboard-grid">

        <div class="dashboard-card">

          <h3>Total Orders</h3>

          <h1 id="orderCount">184</h1>

        </div>

        <div class="dashboard-card">

          <h3>Revenue</h3>

          <h1 id="revenueText">Rp 12.400.000</h1>

        </div>

        <div class="dashboard-card">

          <h3>Current Role</h3>

          <p id="roleText">Customer</p>

        </div>

      </div>

      <div class="dashboard-card" style="margin-top:30px;">

        <h2>Automatic Ingredient Stock</h2>

        <table class="stock-table">

          <tr>
            <th>Ingredient</th>
            <th>Stock</th>
          </tr>

          <tr>
            <td>Gula</td>
            <td id="sugarStock">100 gr</td>
          </tr>

          <tr>
            <td>Milk</td>
            <td id="milkStock">10 L</td>
          </tr>

          <tr>
            <td>Espresso Beans</td>
            <td id="beanStock">4000 gr</td>
          </tr>

        </table>

        <p class="stock-warning" id="stockWarning"></p>

      </div>

    </section>

  </div>

  <!-- REVIEWS -->

  <div id="reviews" class="page">

    <section class="container">

      <div class="section-title">
        <h2>Customer Reviews</h2>
      </div>

      <input type="text" id="username" placeholder="Nama Anda">

      <select id="rating">

        <option value="5">⭐⭐⭐⭐⭐</option>
        <option value="4">⭐⭐⭐⭐</option>
        <option value="3">⭐⭐⭐</option>

      </select>

      <textarea id="reviewText" placeholder="Tulis review..."></textarea>

      <button class="btn btn-primary" onclick="submitReview()">
        Kirim Review
      </button>

      <div id="reviewsContainer"></div>

    </section>

  </div>

  <!-- RESERVATION -->

  <div id="reservation" class="page">

    <section class="container">

      <div class="section-title">

        <h2>Reserve Your Table</h2>

      </div>

      <input type="text" id="reserveName" placeholder="Your Name">

      <input type="date" id="reserveDate">

      <select>

        <option>2 People</option>
        <option>4 People</option>
        <option>6 People</option>

      </select>

      <button class="btn btn-primary" onclick="reserveTable()">

        Confirm Reservation

      </button>

    </section>

  </div>

  <!-- CONTACT -->

  <div id="contact" class="page">

    <section class="container">

      <div class="section-title">
        <h2>Contact Us</h2>
      </div>

      <input type="text" placeholder="Full Name">

      <input type="email" placeholder="Email">

      <textarea rows="6" placeholder="Message"></textarea>

      <button class="btn btn-primary" onclick="showToast('Message Sent Successfully')">

        Submit

      </button>

    </section>

  </div>

  <!-- FOOTER -->

  <div class="footer">

    <div class="footer-grid">

      <div>

        <h2>Wlafē Roastery</h2>

        <p>Luxury coffee experience.</p>

      </div>

      <div>

        <h3>Social Media</h3>

        <p>Instagram : @wlaferoastery</p>

        <p>TikTok : @wlaferoastery</p>

      </div>

      <div>

        <h3>Contact</h3>

        <p>Jl. Mojopahit No.12 Surabaya</p>

        <p>082343987321</p>

      </div>

    </div>

  </div>

  <!-- CART -->

  <div class="cart-sidebar" id="cartSidebar">

    <div class="cart-header">

      <h2>Your Cart</h2>

      <span class="close-cart" onclick="closeCart()">
        ×
      </span>

    </div>

    <div id="cartItems"></div>

    <h3 id="totalPrice">Total: Rp 0</h3>

    <br>

    <button class="btn btn-primary" style="width:100%" onclick="openCheckout()">

      Checkout

    </button>

  </div>

  <!-- CHECKOUT -->

  <div class="modal" id="checkoutModal">

    <div class="modal-box">

      <h2>Checkout</h2>

      <input type="text" placeholder="Nama">

      <input type="text" placeholder="Nomor Telepon">

      <select id="deliveryMethod">

        <option>Pickup Store</option>

        <option>Take Away</option>

        <option>Grab Delivery</option>

      </select>

      <div class="payment-options">

        <div class="payment-option" onclick="selectPayment(this)">
          OVO
        </div>

        <div class="payment-option" onclick="selectPayment(this)">
          GoPay
        </div>

        <div class="payment-option" onclick="selectPayment(this)">
          DANA
        </div>

        <div class="payment-option" onclick="selectPayment(this)">
          BCA
        </div>

        <div class="payment-option" onclick="selectPayment(this)">
          BNI
        </div>

        <div class="payment-option" onclick="selectPayment(this)">
          Mandiri
        </div>

      </div>

      <button class="btn btn-primary" onclick="placeOrder()">



        Place Order

      </button>

    </div>

  </div>

  <!-- LOGIN -->

  <div class="modal" id="authModal">

    <div class="modal-box">

      <h2 style="margin-bottom:20px">
        Login / Register
      </h2>

      <input type="text" id="authName" placeholder="Nama Lengkap">

      <input type="email" id="authEmail" placeholder="Email">

      <input type="password" id="authPassword" placeholder="Password">

      <button class="btn btn-primary" style="width:100%" onclick="loginUser()">

        Login

      </button>

      <button class="btn btn-outline" style="width:100%;color:black;border:1px solid black;margin-top:10px"
        onclick="registerUser()">

        Register

      </button>

      <button class="btn btn-outline" style="width:100%;color:black;border:1px solid black;margin-top:10px"
        onclick="closeAuth()">

        Close

      </button>

    </div>

  </div>

  <!-- TOAST -->

  <div class="toast" id="toast"></div>

  <script>

    let cart = [];

    let sugarStock = 100;
    let milkStock = 10;
    let beanStock = 4000;

    let revenue = 12400000;
    let totalOrders = 184;

    let currentUser = null;

    /* MOBILE MENU */

    function toggleNav() {

      document.getElementById('navLinks')
        .classList.toggle('show');

    }

    /* PAGE */

    function showPage(page) {

      document.querySelectorAll('.page')
        .forEach(p => p.classList.remove('active'));

      document.getElementById(page)
        .classList.add('active');

      window.scrollTo(0, 0);

    }

    /* LOGIN */

    function openAuth() {

      document.getElementById('authModal')
        .style.display = 'flex';

    }

    function closeAuth() {

      document.getElementById('authModal')
        .style.display = 'none';

    }

    function registerUser() {

      const name =
        document.getElementById('authName').value;

      const email =
        document.getElementById('authEmail').value;

      const password =
        document.getElementById('authPassword').value;

      if (name === '' || email === '' || password === '') {

        showToast('Lengkapi data register');

        return;

      }

      localStorage.setItem('wlafeUser',
        JSON.stringify({
          name,
          email,
          password
        }));

      showToast('Register berhasil');

    }

    function loginUser() {

      const email =
        document.getElementById('authEmail').value;

      const password =
        document.getElementById('authPassword').value;

      const user =
        JSON.parse(localStorage.getItem('wlafeUser'));

      if (!user) {

        showToast('Akun belum terdaftar');

        return;

      }

      if (user.email !== email ||
        user.password !== password) {

        showToast('Email / password salah');

        return;

      }

      currentUser = user;

      document.getElementById('roleText')
        .innerText = 'Customer';

      showToast('Welcome ' + user.name);

      closeAuth();

    }

    /* CART */

    function toggleCart() {

      if (!currentUser) {

        showToast('Login terlebih dahulu');

        openAuth();

        return;

      }

      document.getElementById('cartSidebar')
        .classList.toggle('active');

    }

    function closeCart() {

      document.getElementById('cartSidebar')
        .classList.remove('active');

    }

    /* ADD CART */

    function addToCart(name, price, icon) {

      if (!currentUser) {

        showToast('Silahkan login dahulu');

        openAuth();

        return;

      }

      const existing =
        cart.find(i => i.name === name);

      if (existing) {

        existing.qty++;

      } else {

        cart.push({
          name,
          price,
          icon,
          qty: 1
        });

      }

      /* STOCK REDUCTION */

      sugarStock -= 2;
      milkStock -= 0.3;
      beanStock -= 18;

      if (sugarStock < 0) sugarStock = 0;
      if (milkStock < 0) milkStock = 0;
      if (beanStock < 0) beanStock = 0;

      document.getElementById('sugarStock')
        .innerText =
        sugarStock.toFixed(0) + ' gr';

      document.getElementById('milkStock')
        .innerText =
        milkStock.toFixed(1) + ' L';

      document.getElementById('beanStock')
        .innerText =
        beanStock.toFixed(0) + ' gr';

      /* WARNING */

      if (
        sugarStock <= 20 ||
        milkStock <= 2 ||
        beanStock <= 500
      ) {

        document.getElementById('stockWarning')
          .innerText =
          '⚠ Stock hampir habis, segera restock!';

      }

      renderCart();

      showToast(name + ' ditambahkan');

    }

    /* RENDER CART */

    function renderCart() {

      const cartItems =
        document.getElementById('cartItems');

      cartItems.innerHTML = '';

      let total = 0;

      cart.forEach(item => {

        total += item.price * item.qty;

        cartItems.innerHTML += `

    <div class="cart-item">

    <div>

    <b>${item.icon} ${item.name}</b><br>

    Rp ${item.price.toLocaleString('id-ID')}

    </div>

    <div class="qty">

    <button onclick="changeQty('${item.name}',-1)">
    -
    </button>

    ${item.qty}

    <button onclick="changeQty('${item.name}',1)">
    +
    </button>

    </div>

    </div>

    `;

      });

      document.getElementById('cartCount')
        .innerText =
        cart.reduce((a, b) => a + b.qty, 0);

      document.getElementById('totalPrice')
        .innerText =
        'Total: Rp ' +
        total.toLocaleString('id-ID');

    }

    /* CHANGE QTY */

    function changeQty(name, delta) {

      const item =
        cart.find(i => i.name === name);

      if (!item) return;

      item.qty += delta;

      if (item.qty <= 0) {

        cart =
          cart.filter(i => i.name !== name);

      }

      renderCart();

    }

    /* CHECKOUT */

    function openCheckout() {

      if (cart.length === 0) {

        showToast('Cart kosong');

        return;

      }

      document.getElementById('checkoutModal')
        .style.display = 'flex';

    }

    function selectPayment(el) {

      document.querySelectorAll('.payment-option')
        .forEach(p => p.classList.remove('active'));

      el.classList.add('active');

    }

    function placeOrder() {

      const payment =
        document.querySelector('.payment-option.active');

      if (!payment) {

        showToast('Pilih pembayaran');

        return;

      }

      let total = 0;

      let orderText = '';

      cart.forEach(item => {

        total += item.price * item.qty;

        orderText +=
          `${item.name} x${item.qty} - Rp ${(item.price * item.qty).toLocaleString('id-ID')}%0A`;

      });

      revenue += total;
      totalOrders += 1;

      document.getElementById('revenueText')
        .innerText =
        'Rp ' +
        revenue.toLocaleString('id-ID');

      document.getElementById('orderCount')
        .innerText =
        totalOrders;

      /* DATA CUSTOMER */

      const customerName =
        currentUser.name;

      const delivery =
        document.getElementById('deliveryMethod').value;

      const paymentMethod =
        payment.innerText;

      /* FORMAT PESAN WHATSAPP */

      const whatsappMessage =
        `Halo Wlafē Roastery ☕%0A%0A` +

        `Saya ingin melakukan pesanan:%0A%0A` +

        orderText +

        `%0ATotal: Rp ${total.toLocaleString('id-ID')}%0A` +

        `Delivery: ${delivery}%0A` +

        `Payment: ${paymentMethod}%0A` +

        `Nama Customer: ${customerName}`;

      /* NOMOR WHATSAPP CAFE */

      const whatsappNumber = '628234987321';

      /* OPEN WHATSAPP */

      window.open(
        `https://wa.me/${whatsappNumber}?text=${whatsappMessage}`,
        '_blank'
      );

      showToast('Pesanan berhasil dibuat');

      cart = [];

      renderCart();

      document.getElementById('checkoutModal')
        .style.display = 'none';

      closeCart();

    }

    /* REVIEW */

    function submitReview() {

      const username =
        document.getElementById('username').value;

      const rating =
        document.getElementById('rating').value;

      const review =
        document.getElementById('reviewText').value;

      if (username === '' || review === '') {

        showToast('Lengkapi review');

        return;

      }

      document.getElementById('reviewsContainer')
        .innerHTML += `

    <div class="review-card">

    <h3>${username}</h3>

    <p>${'⭐'.repeat(rating)}</p>

    <p>${review}</p>

    </div>

    `;

      showToast('Review berhasil');

    }

    /* RESERVATION */

    function reserveTable() {

      if (!currentUser) {

        showToast('Login terlebih dahulu');

        openAuth();

        return;

      }

      const name =
        document.getElementById('reserveName').value;

      const date =
        document.getElementById('reserveDate').value;

      if (name === '' || date === '') {

        showToast('Lengkapi reservasi');

        return;

      }

      showToast(
        'Reservasi berhasil untuk ' + name
      );

    }

    /* FILTER */

    function filterMenu(category, btn) {

      document.querySelectorAll('.filter-btn')
        .forEach(b => b.classList.remove('active'));

      btn.classList.add('active');

      document.querySelectorAll('.menu-item')
        .forEach(item => {

          if (category === 'all' ||
            item.classList.contains(category)) {

            item.style.display = 'block';

          } else {

            item.style.display = 'none';

          }

        });

    }

    /* TOAST */

    function showToast(message) {

      const toast =
        document.getElementById('toast');

      toast.innerText = message;

      toast.style.display = 'block';

      setTimeout(() => {

        toast.style.display = 'none';

      }, 3000);

    }

    /* INIT */

    renderCart();

  </script>

</body>

